# Postgres (durable ledger + audit trail)
DATABASE_URL=postgresql+psycopg://janus:janus@localhost:5432/janus

# Redis (atomic daily cap / velocity counters)
REDIS_URL=redis://localhost:6379/0

# Paystack (test mode secret key — starts with sk_test_)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co

# Hard ceiling on total exposure, independent of policy
FLOAT_LIMIT_NGN=2000

# Used to build links in approval emails — change if the approver isn't on localhost
BASE_URL=http://localhost:8000

# needs_approval escalation channel: "email" (working) or "telegram" (stub, not wired yet)
APPROVAL_CHANNEL=email
APPROVAL_TIMEOUT_SECONDS=300

# Gmail SMTP: use an App Password (myaccount.google.com/apppasswords), not your login password —
# regular passwords are rejected once 2FA is on, which is required to generate an App Password anyway.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
APPROVAL_EMAIL_FROM=
APPROVAL_EMAIL_TO=

# Telegram (stub only — APPROVAL_CHANNEL=telegram raises NotImplementedError until this is built)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
